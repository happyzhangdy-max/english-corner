reading:'ペンギン',meaning:'企鹅',type:'名',appear:4,years:[2020,2021,2022,2023,2024],ex_jp:'ペンギンが歩いています。',ex_read:'ペンギン が あるいています。',ex_cn:'企鹅在走路。',ex_extra:[],category:'買い物・お金'},{id:2047,level:'n4',word:'カラス',reading:'からす',meaning:'乌鸦',type:'名',appear:4,years:[2020,2021,2022,2023,2024],ex_jp:'カラスが鳴いています。',ex_read:'からす が ないています。',ex_cn:'乌鸦在叫。',ex_extra:[],category:'趣味・娯楽'},{id:2048,level:'n4',word:'雀',reading:'すずめ',meaning:'麻雀',type:'名',appear:4,years:[2020,2021,2022,2023,2024],ex_jp:'雀が庭にいます。',ex_read:'すずめ が にわ に います。',ex_cn:'麻雀在院子里。',ex_extra:[],category:'趣味・娯楽'},{id:2049,level:'n4',word:'ハト',reading:'はと',meaning:'鸽子',type:'名',appear:4,years:[2020,2021,2022,2023,2024],ex_jp:'ハトに餌をあげます。',ex_read:'はと に えさ を あげます。',ex_cn:'喂鸽子。',ex_extra:[],category:'感情・性格'},{id:2050,level:'n1',word:'昆虫',reading:'こんちゅう',meaning:'昆虫',type:'名',appear:4,years:[2020,2021,2022,2023,2024],ex_jp:'昆虫を観察します。',ex_read:'こんちゅう を かんさつ します。',ex_cn:'观察昆虫。',ex_extra:[],category:'自然・天気'},{id:2051,level:'n5',word:'木',reading:'き',meaning:'树',type:'名',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'木が大きくなりました。',ex_read:'き が おおきく なりました。',ex_cn:'树长大了。',ex_extra:[],category:'自然・天気'},{id:2052,level:'n4',word:'草',reading:'くさ',meaning:'草',type:'名',appear:5,years:[2020,2021,2022,2023,2024],ex_jp:'草が伸びました。',ex_read:'くさ が のびました。',ex_cn:'草长长了。',ex_extra:[],category:'自然・天気'},{id:2053,level:'n4',word:'菊',reading:'きく',meaning:'菊花',type:'名',appear:4,years:[2020,2021,2022,2023,2024],ex_jp:'菊の花が美しい。',ex_read:'きく の はな が うつくしい。',ex_cn:'菊花很美。',ex_extra:[],category:'自然・天気'},{id:2054,level:'n4',word:'バラ',reading:'ばら',meaning:'玫瑰',type:'名',appear:5,years:[2020,2021,2022,2023,2024],ex_jp:'バラの花束をもらいました。',ex_read:'ばら の はなたば を もらいました。',ex_cn:'收到了玫瑰花束。',ex_extra:[],category:'自然・天気'},{id:2055,level:'n4',word:'ひまわり',reading:'ひまわり',meaning:'向日葵',type:'名',appear:4,years:[2020,2021,2022,2023,2024],ex_jp:'ひまわりが咲いています。',ex_read:'ひまわり が さいています。',ex_cn:'向日葵开着。',ex_extra:[],category:'社会・政治'},{id:2056,level:'n4',word:'林',reading:'はやし',meaning:'树林'