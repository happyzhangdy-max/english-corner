],category:'言語・コミュニケーション'},{id:1787,level:'n5',word:'口',reading:'くち',meaning:'嘴',type:'名',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'口を開けてください。',ex_read:'くち を あけて ください。',ex_cn:'请张开嘴。',ex_extra:[],category:'趣味・娯楽'},{id:1788,level:'n5',word:'鼻',reading:'はな',meaning:'鼻子',type:'名',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'鼻が高いです。',ex_read:'はな が たかい です。',ex_cn:'鼻子高。',ex_extra:[],category:'性質・特徴'},{id:1789,level:'n5',word:'顔',reading:'かお',meaning:'脸',type:'名',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'顔を洗います。',ex_read:'かお を あらいます。',ex_cn:'洗脸。',ex_extra:[],category:'感情・性格'},{id:1790,level:'n5',word:'ここ',reading:'ここ',meaning:'这里',type:'代',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'ここに置いてください。',ex_read:'ここ に おいて ください。',ex_cn:'请放在这里。',ex_extra:[],category:'抽象・概念'},{id:1791,level:'n5',word:'そこ',reading:'そこ',meaning:'那里',type:'代',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'そこに座ってください。',ex_read:'そこ に すわって ください。',ex_cn:'请坐在那里。',ex_extra:[],category:'抽象・概念'},{id:1792,level:'n5',word:'あそこ',reading:'あそこ',meaning:'那边',type:'代',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'あそこに見えます。',ex_read:'あそこ に みえます。',ex_cn:'能看到那边。',ex_extra:[],category:'抽象・概念'},{id:1793,level:'n5',word:'こちら',reading:'こちら',meaning:'这边（礼貌）',type:'代',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'こちらへどうぞ。',ex_read:'こちら へ どうぞ。',ex_cn:'请这边走。',ex_extra:[],category:'抽象・概念'},{id:1794,level:'n5',word:'そちら',reading:'そちら',meaning:'那边（礼貌）',type:'代',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'そちらは何ですか。',ex_read:'そちら は なん ですか。',ex_cn:'那边是什么？',ex_extra:[],category:'抽象・概念'},{id:1795,level:'n5',word:'あちら',reading:'あちら',meaning:'那边（礼貌远称）',type:'代',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'あちらが出口です。',ex_read:'あちら が でぐち です。',ex_cn:'那边是出口。',ex_extra:[],category:'場所・建物'},{id:1796,level:'n5',word:'これ',reading:'これ',meaning:'这个',type:'代',appear:10,years:[2020,2021,2022,2023,2024],ex_jp:'これは日本語の教科書です。',ex_read:'これ は ほん です。',ex_cn:'这是书。',ex_extra:[],category:'学校・教育'},{id:1797,level:'n5',word:'あれ',reading:'あれ',meaning:'那个（远称）',type:'代',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'あれが富士山です。',ex_read:'あれ は やま です。',ex_cn:'那是山。',ex_extra:[],category:'自然・天気'},{id:1798,level:'n5',word:'どれ',reading:'どれ',meaning:'哪个',type:'代',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'どれが好きですか。',ex_read:'どれ が すき ですか。',ex_cn:'喜欢哪个？',ex_extra:[],category:'感情・性格'},{id:1799,level:'n5',word:'その',reading:'その',meaning:'那个（连体）',type:'連体',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'その店は安いです。',ex_read:'その みせ は やすい です。',ex_cn:'那家店便宜。',ex_extra:[],category:'抽象・概念'},{id:1800,level:'n5',word:'あの',reading:'あの',meaning:'那个（连体远称）',type:'連体',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'あの人は誰ですか。',ex_read:'あの ひと は だれ ですか。',ex_cn:'那个人是谁？',ex_extra:[],category:'抽象・概念'},{id:1801,level:'n5',word:'どう',reading:'どう',meaning:'如何',type:'副',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'日本語はどうですか。',ex_read:'にほんご は どう ですか。',ex_cn:'日语怎么样？',ex_extra:[],category:'言語・コミュニケーション'},{id:1802,level:'n5',word:'なぜ',reading:'なぜ',meaning:'为什么',type:'副',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'なぜ遅刻しましたか。',ex_read:'なぜ ちこく しましたか。',ex_cn:'为什么迟到了？',ex_extra:[],category:'学校・教育'},{id:1803,level:'n5',word:'どうして',reading:'どうして',meaning:'为什么',type:'副',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'どうして泣いているの。',ex_read:'どうして ないている の。',ex_cn:'为什么在哭？',ex_extra:[],category:'抽象・概念'},{id:1804,level:'n5',word:'いくつ',reading:'いくつ',meaning:'几个；几岁',type:'名',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'いくつありますか。',ex_read:'いくつ ありますか。',ex_cn:'有几个？',ex_extra:[],category:'社会・政治'},{id:1805,level:'n5',word:'あまり',reading:'あまり',meaning:'不太（否定）',type:'副',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'あまり好きじゃありません。',ex_read:'あまり すき じゃ ありません。',ex_cn:'不太喜欢。',ex_extra:[],category:'感情・性格'},{id:1806,level:'n5',word:'少し',reading:'すこし',meaning:'一点点',type:'副',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'少し待ってください。',ex_read:'すこし まって ください。',ex_cn:'请稍等。',ex_extra:[],category:'抽象・概念'},{id:1807,level:'n4',word:'もちろん',reading:'もちろん',meaning:'当然',type:'副',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'もちろん行きます。',ex_read:'もちろん いきます。',ex_cn:'当然去。',ex_extra:[],category:'抽象・概念'},{id:1808,level:'n5',word:'ちょっと',reading:'ちょっと',meaning:'稍微',type:'副',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'ちょっと待ってください。',ex_read:'ちょっと まって ください。',ex_cn:'请稍等一下。',ex_extra:[],category:'抽象・概念'},{id:1809,level:'n5',word:'どうぞ',reading:'どうぞ',meaning:'请',type:'副',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'どうぞお入りください。',ex_read:'どうぞ おはいり ください。',ex_cn:'请进。',ex_extra:[],category:'抽象・概念'},{id:1810,level:'n5',word:'どうも',reading:'どうも',meaning:'真是；总觉得',type:'副',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'どうもありがとう。',ex_read:'どうも ありがとう。',ex_cn:'非常感谢。',ex_extra:[],category:'抽象・概念'},{id:1811,level:'n5',word:'さあ',reading:'さあ',meaning:'来吧；好了',type:'感',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'さあ、行きましょう。',ex_read:'さあ、いきましょう。',ex_cn:'好了，走吧。',ex_extra:[],category:'抽象・概念'},{id:1812,level:'n5',word:'もしもし',reading:'もしもし',meaning:'喂（电话）',type:'感',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'もしもし、田中です。',ex_read:'もしもし、たなか です。',ex_cn:'喂，我是田中。',ex_extra:[],category:'言語・コミュニケーション'},{id:1813,level:'n4',word:'ほとんど',reading:'ほとんど',meaning:'几乎',type:'副',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'ほとんど終わりました。',ex_read:'ほとんど おわりました。',ex_cn:'几乎结束了。',ex_extra:[],category:'時間・時期'},{id:1814,level:'n3',word:'ちゃんと',reading:'ちゃんと',meaning:'好好地',type:'副',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'ちゃんと食べてください。',ex_read:'ちゃんと たべて ください。',ex_cn:'请好好吃饭。',ex_extra:[],category:'抽象・概念'},{id:1815,level:'n5',word:'一緒に',reading:'いっしょに',meaning:'一起',type:'副',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'一緒に行きましょう。',ex_read:'いっしょ に いきましょう。',ex_cn:'一起去吧。',ex_extra:[],category:'抽象・概念'},{id:1816,level:'n3',word:'急に',reading:'きゅうに',meaning:'突然',type:'副',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'急に雨が降りました。',ex_read:'きゅうに あめ が ふりました。',ex_cn:'突然下雨了。',ex_extra:[],category:'自然・天気'},{id:1817,level:'n2',word:'本当に',reading:'ほんとうに',meaning:'真的',type:'副',appear:3,years:[2019,2020,2021,2022,2023],ex_jp:'本当に間に合うのかなあ。',ex_read:'ほんとうに まにあう の かなあ。',ex_cn:'真的来得及吗？',ex_extra:[],category:'抽象・概念'},{id:1818,level:'n5',word:'もう一度',reading:'もういちど',meaning:'再一次',type:'副',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'もう一度言ってください。',ex_read:'もういちど いって ください。',ex_cn:'请再说一遍。',ex_extra:[],category:'抽象・概念'},{id:1819,level:'n2',word:'初めに',reading:'はじめに',meaning:'首先',type:'副',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'初めに名前を書いてください。',ex_read:'はじめに なまえ を かいて ください。',ex_cn:'首先请写名字。',ex_extra:[],category:'言語・コミュニケーション'},{id:1820,level:'n5',word:'後は',reading:'あとは',meaning:'之后',type:'副',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'後は宿題をします。',ex_read:'あとは しゅくだい を します。',ex_cn:'之后做作业。',ex_extra:[],category:'学校・教育'},{id:1821,level:'n5',word:'です',reading:'です',meaning:'是',type:'助動',appear:10,years:[2020,2021,2022,2023,2024],ex_jp:'私は学生です。',ex_read:'わたし は がくせい です。',ex_cn:'我是学生。',ex_extra:[],category:'学校・教育'},{id:1822,level:'n5',word:'ます',reading:'ます',meaning:'（动词礼貌后缀）',type:'助動',appear:10,years:[2020,2021,2022,2023,2024],ex_jp:'読みます、書きます。',ex_read:'よみます、かきます。',ex_cn:'读、写。',ex_extra:[],category:'抽象・概念'},{id:1823,level:'n5',word:'ない',reading:'ない',meaning:'不（否定）',type:'助形',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'食べない、行かない。',ex_read:'たべない、いかない。',ex_cn:'不吃、不去。',ex_extra:[],category:'抽象・概念'},{id:1824,level:'n5',word:'たい',reading:'たい',meaning:'想（愿望）',type:'助形',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'日本に行きたいです。',ex_read:'にほん に いきたい です。',ex_cn:'想去日本。',ex_extra:[],category:'抽象・概念'},{id:1825,level:'n5',word:'～さん',reading:'～さん',meaning:'~先生/小姐',type:'接尾',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'田中さんはいますか。',ex_read:'たなかさん は いますか。',ex_cn:'田中先生在吗？',ex_extra:[],category:'学校・教育'},{id:1826,level:'n4',word:'～ちゃん',reading:'～ちゃん',meaning:'~酱（昵称）',type:'接尾',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'花子ちゃんは元気？',ex_read:'はなこちゃん は げんき？',ex_cn:'花子酱还好吗？',ex_extra:[],category:'自然・天気'},{id:1827,level:'n5',word:'～人',reading:'～じん/にん',meaning:'~人',type:'接尾',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'日本人、三人。',ex_read:'にほんじん、さんにん。',ex_cn:'日本人、三个人。',ex_extra:[],category:'抽象・概念'},{id:1828,level:'n5',word:'～年',reading:'～ねん',meaning:'~年',type:'接尾',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'2024年です。',ex_read:'2024ねん です。',ex_cn:'2024年。',ex_extra:[],category:'抽象・概念'},{id:1829,level:'n4',word:'～月',reading:'～がつ',meaning:'~月',type:'接尾',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'四月になりました。',ex_read:'しがつ に なりました。',ex_cn:'到四月了。',ex_extra:[],category:'自然・天気'},{id:1830,level:'n2',word:'～日',reading:'～にち',meaning:'~日',type:'接尾',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'十日は休みです。',ex_read:'とおか は やすみ です。',ex_cn:'十号休息。',ex_extra:[],category:'抽象・概念'},{id:1831,level:'n5',word:'～円',reading:'～えん',meaning:'~日元',type:'接尾',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'百円です。',ex_read:'ひゃくえん です。',ex_cn:'一百日元。',ex_extra:[],category:'抽象・概念'},{id:1832,level:'n5',word:'～回',reading:'～かい',meaning:'~次',type:'接尾',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'もう一回してください。',ex_read:'もう いっかい して ください。',ex_cn:'请再做一次。',ex_extra:[],category:'抽象・概念'},{id:1833,level:'n5',word:'～つ',reading:'～つ',meaning:'~个（计数）',type:'接尾',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'一つ、二つ、三つ。',ex_read:'ひとつ、ふたつ、みっつ。',ex_cn:'一个、两个、三个。',ex_extra:[],category:'抽象・概念'},{id:1834,level:'n5',word:'～枚',reading:'～まい',meaning:'~张/片',type:'接尾',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'三枚ください。',ex_read:'さんまい ください。',ex_cn:'请给我三张。',ex_extra:[],category:'抽象・概念'},{id:1835,level:'n5',word:'～冊',reading:'～さつ',meaning:'~册',type:'接尾',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'一冊だけ借ります。',ex_read:'いっさつ だけ かります。',ex_cn:'只借一本。',ex_extra:[],category:'抽象・概念'},{id:1836,level:'n5',word:'～台',reading:'～だい',meaning:'~台',type:'接尾',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'車を一台買いました。',ex_read:'くるま を いちだい かいました。',ex_cn:'买了一辆车。',ex_extra:[],category:'抽象・概念'},{id:1837,level:'n2',word:'～足',reading:'～そく',meaning:'~双',type:'接尾',appear:5,years:[2020,2021,2022,2023,2024],ex_jp:'靴を一足買います。',ex_read:'くつ を いっそく かいます。',ex_cn:'买一双鞋。',ex_extra:[],category:'抽象・概念'},{id:1838,level:'n5',word:'～本',reading:'～ぼん',meaning:'~根/条',type:'接尾',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'ペンを三本ください。',ex_read:'ペン を さんぼん ください。',ex_cn:'请给我三支笔。',ex_extra:[],category:'抽象・概念'},{id:1839,level:'n5',word:'～杯',reading:'～はい',meaning:'~杯',type:'接尾',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'コーヒーを一杯ください。',ex_read:'コーヒー を いっぱい ください。',ex_cn:'请给我一杯咖啡。',ex_extra:[],category:'抽象・概念'},{id:1840,level:'n5',word:'～匹',reading:'～ひき',meaning:'~只（小动物）',type:'接尾',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'猫が三匹います。',ex_read:'ねこ が さんびき います。',ex_cn:'有三只猫。',ex_extra:[],category:'抽象・概念'},{id:1841,level:'n5',word:'～番',reading:'～ばん',meaning:'~号',type:'接尾',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'一番好きです。',ex_read:'いちばん すき です。',ex_cn:'最喜欢。',ex_extra:[],category:'感情・性格'},{id:1842,level:'n5',word:'閉まる',reading:'しまる',meaning:'关闭',type:'动',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'窓が閉まりました。',ex_read:'まど が しまりました。',ex_cn:'窗户关了。',ex_extra:[],category:'性質・特徴'},{id:1843,level:'n4',word:'通る',reading:'とおる',meaning:'通过',type:'动',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'この道を通ります。',ex_read:'この みち を とおります。',ex_cn:'走这条路。',ex_extra:[],category:'場所・建物'},{id:1844,level:'n4',word:'持って行く',reading:'もっていく',meaning:'带去',type:'动',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'傘を持って行きます。',ex_read:'かさ を もって いきます。',ex_cn:'带伞去。',ex_extra:[],category:'性質・特徴'},{id:1845,level:'n4',word:'持って来る',reading:'もってくる',meaning:'带来',type:'动',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'お菓子を持って来ました。',ex_read:'おかし を もって きました。',ex_cn:'带了点心来。',ex_extra:[],category:'食べ物・料理'},{id:1846,level:'n5',word:'つける',reading:'つける',meaning:'打开（灯等）',type:'动',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'電気をつけます。',ex_read:'でんき を つけます。',ex_cn:'开灯。',ex_extra:[],category:'技術・IT'},{id:1847,level:'n4',word:'決まる',reading:'きまる',meaning:'定下来',type:'动',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'予定が決まりました。',ex_read:'よてい が きまりました。',ex_cn:'计划定下来了。',ex_extra:[],category:'思考・判断'},{id:1848,level:'n3',word:'動かす',reading:'うごかす',meaning:'移动；开动',type:'动',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'机を動かします。',ex_read:'つくえ を うごかします。',ex_cn:'移动桌子。',ex_extra:[],category:'動作・活動'},{id:1849,level:'n4',word:'集まる',reading:'あつまる',meaning:'聚集',type:'动',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'駅に集まります。',ex_read:'えき に あつまります。',ex_cn:'在车站集合。',ex_extra:[],category:'旅行・交通'},{id:1850,level:'n4',word:'向かう',reading:'むかう',meaning:'往……去',type:'动',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'学校に向かいます。',ex_read:'がっこう に むかいます。',ex_cn:'往学校去。',ex_extra:[],category:'学校・教育'},{id:1851,level:'n4',word:'迎える',reading:'むかえる',meaning:'迎接',type:'动',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'お客様を迎えます。',ex_read:'おきゃくさま を むかえます。',ex_cn:'迎接客人。',ex_extra:[],category:'性質・特徴'},{id:1852,level:'n3',word:'数える',reading:'かぞえる',meaning:'数',type:'动',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'お金を数えます。',ex_read:'おかね を かぞえます。',ex_cn:'数钱。',ex_extra:[],category:'買い物・お金'},{id:1853,level:'n4',word:'噛む',reading:'かむ',meaning:'咬',type:'动',appear:5,years:[2020,2021,2022,2023,2024],ex_jp:'リンゴを噛みます。',ex_read:'りんご を かみます。',ex_cn:'咬苹果。',ex_extra:[],category:'性質・特徴'},{id:1854,level:'n5',word:'切る',reading:'きる',meaning:'切；剪',type:'动',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'野菜を切ります。',ex_read:'やさい を きります。',ex_cn:'切蔬菜。',ex_extra:[],category:'食べ物・料理'},{id:1855,level:'n4',word:'包む',reading:'つつむ',meaning:'包',type:'动',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'プレゼントを包みます。',ex_read:'プレゼント を つつみます。',ex_cn:'包礼物。',ex_extra:[],category:'動作・活動'},{id:1856,level:'n3',word:'乾かす',reading:'かわかす',meaning:'弄干',type:'动',appear:5,years:[2020,2021,2022,2023,2024],ex_jp:'髪を乾かします。',ex_read:'かみ を かわかします。',ex_cn:'吹干头发。',ex_extra:[],category:'健康・医療'},{id:1857,level:'n3',word:'冷やす',reading:'ひやす',meaning:'冰镇',type:'动',appear:5,years:[2020,2021,2022,2023,2024],ex_jp:'ビールを冷やします。',ex_read:'ビール を 