el:'n3',word:'こんにちは',reading:'こんにちは',meaning:'你好',type:'挨拶',appear:10,years:[2020,2021,2022,2023,2024],ex_jp:'こんにちは、元気ですか。',ex_read:'こんにちは、げんき ですか。',ex_cn:'你好，好吗？',ex_extra:[],category:'言語・コミュニケーション'},{id:1598,level:'n2',word:'こんばんは',reading:'こんばんは',meaning:'晚上好',type:'挨拶',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'こんばんは、お元気ですか。',ex_read:'こんばんは、おげんき ですか。',ex_cn:'晚上好，您好吗？',ex_extra:[],category:'時間・時期'},{id:1599,level:'n5',word:'おはようございます',reading:'おはようございます',meaning:'早上好',type:'挨拶',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'おはようございます、先生。',ex_read:'おはようございます、せんせい。',ex_cn:'早上好，老师。',ex_extra:[],category:'学校・教育'},{id:1600,level:'n2',word:'さようなら',reading:'さようなら',meaning:'再见',type:'挨拶',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'さようなら、また明日。',ex_read:'さようなら、また あした。',ex_cn:'再见，明天见。',ex_extra:[],category:'時間・時期'},{id:1601,level:'n5',word:'ありがとうございます',reading:'ありがとうございます',meaning:'谢谢',type:'挨拶',appear:10,years:[2020,2021,2022,2023,2024],ex_jp:'ご親切にありがとうございます。',ex_read:'ごしんせつ に ありがとう ございます。',ex_cn:'谢谢您的好意。',ex_extra:[],category:'感情・性格'},{id:1602,level:'n5',word:'すみません',reading:'すみません',meaning:'对不起；打扰了',type:'挨拶',appear:10,years:[2020,2021,2022,2023,2024],ex_jp:'すみません、道を教えてください。',ex_read:'すみません、みち を おしえて ください。',ex_cn:'不好意思，请告诉我路。',ex_extra:[],category:'言語・コミュニケーション'},{id:1603,level:'n5',word:'はい',reading:'はい',meaning:'是的',type:'感',appear:10,years:[2020,2021,2022,2023,2024],ex_jp:'はい、分かりました。',ex_read:'はい、わかりました。',ex_cn:'好的，明白了。',ex_extra:[],category:'抽象・概念'},{id:1604,level:'n5',word:'いいえ',reading:'いいえ',meaning:'不是',type:'感',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'いいえ、違います。',ex_read:'いいえ、ちがいます。',ex_cn:'不，不是。',ex_extra:[],category:'抽象・概念'},{id:1605,level:'n2',word:'お願いします',reading:'おねがいします',meaning:'拜托了；请',type:'挨拶',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'お水をお願いします。',ex_read:'おみず を おねがい します。',ex_cn:'请给我水。',ex_extra:[],category:'言語・コミュニケーション'},{id:1606,level:'n3',word:'いただきます',reading:'いただきます',meaning:'我开动了',type:'挨拶',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'いただきます！美味しそう。',ex_read:'いただきます！おいしそう。',ex_cn:'我开动了！看起来好吃。',ex_extra:[],category:'言語・コミュニケーション'},{id:1607,level:'n5',word:'ごちそうさまでした',reading:'ごちそうさまでした',meaning:'多谢款待',type:'挨拶',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'ごちそうさまでした、美味しかったです。',ex_read:'ごちそうさまでした、おいしかったです。',ex_cn:'多谢款待，很好吃。',ex_extra:[],category:'言語・コミュニケーション'},{id:1608,level:'n5',word:'失礼します',reading:'しつれいします',meaning:'失礼了',type:'挨拶',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'失礼します、お先に。',ex_read:'しつれいします、おさきに。',ex_cn:'失礼了，我先走了。',ex_extra:[],category:'感情・性格'},{id:1609,level:'n5',word:'一',reading:'いち',meaning:'一',type:'数',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'一つください。',ex_read:'ひとつ ください。',ex_cn:'请给我一个。',ex_extra:[],category:'数量・比較'},{id:1610,level:'n5',word:'二',reading:'に',meaning:'二',type:'数',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'二つ欲しいです。',ex_read:'ふたつ ほしい です。',ex_cn:'想要两个。',ex_extra:[],category:'数量・比較'},{id:1611,level:'n5',word:'三',reading:'さん',meaning:'三',type:'数',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'りんごが三つあります。',ex_read:'みっつ あります。',ex_cn:'有三个。',ex_extra:[],category:'数量・比較'},{id:1612,level:'n3',word:'四',reading:'し/よん',meaning:'四',type:'数',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'四つお願いします。',ex_read:'よっつ おねがい します。',ex_cn:'请给我四个。',ex_extra:[],category:'数量・比較'},{id:1613,level:'n5',word:'五',reading:'ご',meaning:'五',type:'数',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'五つ買いました。',ex_read:'いつつ かいました。',ex_cn:'买了五个。',ex_extra:[],category:'数量・比較'},{id:1614,level:'n5',word:'六',reading:'ろく',meaning:'六',type:'数',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'六時です。',ex_read:'ろくじ です。',ex_cn:'六点了。',ex_extra:[],category:'数量・比較'},{id:1615,level:'n5',word:'七',reading:'しち/なな',meaning:'七',type:'数',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'七時半です。',ex_read:'しちじ はん です。',ex_cn:'七点半了。',ex_extra:[],category:'数量・比較'},{id:1616,level:'n5',word:'八',reading:'はち',meaning:'八',type:'数',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'八時からです。',ex_read:'はちじ から です。',ex_cn:'从八点开始。',ex_extra:[],category:'数量・比較'},{id:1617,level:'n5',word:'九',reading:'く/きゅう',meaning:'九',type:'数',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'九時までです。',ex_read:'くじ まで です。',ex_cn:'到九点为止。',ex_extra:[],category:'数量・比較'},{id:1618,level:'n5',word:'十',reading:'じゅう',meaning:'十',type:'数',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'十人いました。',ex_read:'じゅうにん いました。',ex_cn:'有十个人。',ex_extra:[],category:'数量・比較'},{id:1619,level:'n5',word:'百',reading:'ひゃく',meaning:'百',type:'数',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'百円です。',ex_read:'ひゃくえん です。',ex_cn:'一百日元。',ex_extra:[],category:'数量・比較'},{id:1620,level:'n5',word:'千',reading:'せん',meaning:'千',type:'数',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'千円札です。',ex_read:'せんえんさつ です。',ex_cn:'是一千日元纸币。',ex_extra:[],category:'数量・比較'},{id:1621,level:'n5',word:'万',reading:'まん',meaning:'万',type:'数',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'一万円を払いました。',ex_read:'いちまんえん を はらいました。',ex_cn:'付了一万日元。',ex_extra:[],category:'数量・比較'},{id:1622,level:'n5',word:'いくら',reading:'いくら',meaning:'多少钱',type:'数',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'これはいくらですか。',ex_read:'これ は いくら ですか。',ex_cn:'这个多少钱？',ex_extra:[],category:'買い物・お金'},{id:1623,level:'n5',word:'何時',reading:'なんじ',meaning:'几点',type:'数',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'今何時ですか。',ex_read:'いま なんじ ですか。',ex_cn:'现在几点？',ex_extra:[],category:'数量・比較'},{id:1624,level:'n5',word:'毎朝',reading:'まいあさ',meaning:'每天早上',type:'名',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'毎朝ジョギングします。',ex_read:'まいあさ ジョギング します。',ex_cn:'每天早上慢跑。',ex_extra:[],category:'趣味・娯楽'},{id:1625,level:'n5',word:'毎晩',reading:'まいばん',meaning:'每天晚上',type:'名',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'毎晩テレビを見ます。',ex_read:'まいばん テレビ を みます。',ex_cn:'每天晚上看电视。',ex_extra:[],category:'趣味・娯楽'},{id:1626,level:'n5',word:'昼',reading:'ひる',meaning:'白天；中午',type:'名',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'昼ごはんを食べましょう。',ex_read:'ひるごはん を たべましょう。',ex_cn:'吃午饭吧。',ex_extra:[],category:'時間・時期'},{id:1627,level:'n5',word:'午前',reading:'ごぜん',meaning:'上午',type:'名',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'午前十時です。',ex_read:'ごぜん じゅうじ です。',ex_cn:'上午十点。',ex_extra:[],category:'時間・時期'},{id:1628,level:'n5',word:'午後',reading:'ごご',meaning:'下午',type:'名',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'午後から勉強します。',ex_read:'ごご から べんきょう します。',ex_cn:'从下午开始学习。',ex_extra:[],category:'学校・教育'},{id:1629,level:'n5',word:'～時',reading:'～じ',meaning:'~点',type:'助数',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'三時に会いましょう。',ex_read:'さんじ に あいましょう。',ex_cn:'三点见吧。',ex_extra:[],category:'抽象・概念'},{id:1630,level:'n5',word:'～分',reading:'～ふん/ぷん',meaning:'~分',type:'助数',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'十分かかります。',ex_read:'じっぷん かかります。',ex_cn:'需要十分钟。',ex_extra:[],category:'抽象・概念'},{id:1631,level:'n5',word:'毎週',reading:'まいしゅう',meaning:'每周',type:'名',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'毎週水曜日に会います。',ex_read:'まいしゅう すいようび に あいます。',ex_cn:'每周三见面。',ex_extra:[],category:'時間・時期'},{id:1632,level:'n5',word:'毎月',reading:'まいつき',meaning:'每月',type:'名',appear:6,years:[2020,2021,2022,2023,2024],ex_jp:'毎月一度映画を見ます。',ex_read:'まいつき いちど えいが を みます。',ex_cn:'每月看一次电影。',ex_extra:[],category:'趣味・娯楽'},{id:1633,level:'n5',word:'毎年',reading:'まいとし',meaning:'每年',type:'名',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'毎年旅行に行きます。',ex_read:'まいとし りょこう に いきます。',ex_cn:'每年去旅行。',ex_extra:[],category:'旅行・交通'},{id:1634,level:'n5',word:'今週',reading:'こんしゅう',meaning:'这周',type:'名',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'今週の予定は？',ex_read:'こんしゅう の よてい は？',ex_cn:'这周的安排是？',ex_extra:[],category:'時間・時期'},{id:1635,level:'n5',word:'今月',reading:'こんげつ',meaning:'这个月',type:'名',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'今月はお金がありません。',ex_read:'こんげつ は おかね が ありません。',ex_cn:'这个月没钱。',ex_extra:[],category:'買い物・お金'},{id:1636,level:'n5',word:'今年',reading:'ことし',meaning:'今年',type:'名',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'今年もよろしくお願いします。',ex_read:'ことし も よろしく おねがい します。',ex_cn:'今年也请多关照。',ex_extra:[],category:'時間・時期'},{id:1637,level:'n5',word:'よく',reading:'よく',meaning:'经常；好地',type:'副',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'よく図書館に行きます。',ex_read:'よく としょかん に いきます。',ex_cn:'经常去图书馆。',ex_extra:[],category:'学校・教育'},{id:1638,level:'n4',word:'たまに',reading:'たまに',meaning:'偶尔',type:'副',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'たまに外食します。',ex_read:'たまに がいしょく します。',ex_cn:'偶尔在外面吃饭。',ex_extra:[],category:'抽象・概念'},{id:1639,level:'n5',word:'もう',reading:'もう',meaning:'已经；再',type:'副',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'もう帰りましたか。',ex_read:'もう かえりました か。',ex_cn:'已经回去了吗？',ex_extra:[],category:'抽象・概念'},{id:1640,level:'n5',word:'まだ',reading:'まだ',meaning:'还；仍',type:'副',appear:9,years:[2020,2021,2022,2023,2024],ex_jp:'まだ終わっていません。',ex_read:'まだ おわって いません。',ex_cn:'还没结束。',ex_extra:[],category:'抽象・概念'},{id:1641,level:'n5',word:'すぐ',reading:'すぐ',meaning:'马上',type:'副',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'すぐに戻ってきます。',ex_read:'すぐ きます。',ex_cn:'马上来。',ex_extra:[],category:'抽象・概念'},{id:1642,level:'n4',word:'さっき',reading:'さっき',meaning:'刚才',type:'副',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'さっき電話がありました。',ex_read:'さっき でんわ が ありました。',ex_cn:'刚才有电话。',ex_extra:[],category:'言語・コミュニケーション'},{id:1643,level:'n5',word:'後で',reading:'あとで',meaning:'待会儿',type:'副',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'後で連絡します。',ex_read:'あとで れんらく します。',ex_cn:'待会儿联系。',ex_extra:[],category:'言語・コミュニケーション'},{id:1644,level:'n5',word:'前に',reading:'まえに',meaning:'之前',type:'副',appear:7,years:[2020,2021,2022,2023,2024],ex_jp:'前に見た映画です。',ex_read:'まえに みた えいが です。',ex_cn:'之前看过的电影。',ex_extra:[],category:'趣味・娯楽'},{id:1645,level:'n5',word:'初めて',reading:'はじめて',meaning:'第一次',type:'副',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'初めて日本に来ました。',ex_read:'はじめて にほん に きました。',ex_cn:'第一次来日本。',ex_extra:[],category:'時間・時期'},{id:1646,level:'n4',word:'最近',reading:'さいきん',meaning:'最近',type:'名',appear:8,years:[2020,2021,2022,2023,2024],ex_jp:'最近どうですか。',ex_read:'さいきん どう ですか。',ex_cn:'最近怎么样？',ex_extra:[],category:'旅行・交通'},{id:1647